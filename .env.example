# Copy this to .env and fill in your real keys
# NEVER commit .env to git

# JSONBin.io master key for cloud sync
# Get from jsonbin.io → Account → API Keys
VITE_JSONBIN_KEY=your_jsonbin_master_key_here

# Anthropic API key for the AI chat tab
# Get from console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
